@using FinanManager.Models
@model dynamic
@{
    ViewData["Title"] = "Detalles del Presupuesto";
}

<h2>Detalles del Presupuesto</h2>

<div>
    <h4>@Model.GetType().Name</h4>
    <hr />
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Campo</th>
                <th>Valor</th>
            </tr>
        </thead>
        <tbody>
            @if (Model is Bienes)
            {
                <tr>
                    <td>Descripción</td>
                    <td>@Model.Descripcion</td>
                </tr>
                <tr>
                    <td>Cantidad</td>
                    <td>@Model.Cantidad</td>
                </tr>
                <tr>
                    <td>Monto Unitario</td>
                    <td>@Model.MontoUnitario</td>
                </tr>
                <tr>
                    <td>Total</td>
                    <td>@Model.Total</td>
                </tr>
                <tr>
                    <td>Periodo de ejecución</td>
                    <td>
                        @{
                            var meses = new List<string>();
                            if (Model.Enero == 1) meses.Add("Enero");
                            if (Model.Febrero == 1) meses.Add("Febrero");
                            if (Model.Marzo == 1) meses.Add("Marzo");
                            if (Model.Abril == 1) meses.Add("Abril");
                            if (Model.Mayo == 1) meses.Add("Mayo");
                            if (Model.Junio == 1) meses.Add("Junio");
                            if (Model.Julio == 1) meses.Add("Julio");
                            if (Model.Agosto == 1) meses.Add("Agosto");
                            if (Model.Septiembre == 1) meses.Add("Septiembre");
                            if (Model.Octubre == 1) meses.Add("Octubre");
                            if (Model.Noviembre == 1) meses.Add("Noviembre");
                            if (Model.Diciembre == 1) meses.Add("Diciembre");
                        }
                        @string.Join(", ", meses)
                    </td>
                </tr>
                <tr>
                    <td>Estado</td>
                    <td>
                        @switch (Model.StatusId)
                        {
                            case 1:
                                <span class="text-danger">Rechazado</span>
                                break;
                            case 2:
                                <span class="text-warning">Pendiente</span>
                                break;
                            case 3:
                                <span class="text-success">Aprobado</span>
                                break;
                        }
                    </td>
                </tr>
                <tr>
                    <td>Fecha</td>
                    <td>@Model.Fecha.ToShortDateString()</td>
                </tr>
                @if (Model.MotivoRechazo != null)
                {
                    <tr>
                        <td>Motivo de Rechazo</td>
                        <td>@Model.MotivoRechazo</td>
                    </tr>
                }
            }
            else if (Model is Gasto)
            {
                <tr>
                    <td>Cuenta Madre</td>
                    <td>@Model.CuentaMadreId</td>
                </tr>
                <tr>
                    <td>Cuenta Hija</td>
                    <td>@Model.CuentaHijaId</td>
                </tr>
                <tr>
                    <td>Justificación</td>
                    <td>@Model.Justificacion</td>
                </tr>
                <tr>
                    <td>Total</td>
                    <td>@Model.Total</td>
                </tr>
                <tr>
                    <td>Periodo de ejecución</td>
                    <td>
                        @{
                            var meses = new List<string>();
                            if (Model.Enero == 1) meses.Add("Enero");
                            if (Model.Febrero == 1) meses.Add("Febrero");
                            if (Model.Marzo == 1) meses.Add("Marzo");
                            if (Model.Abril == 1) meses.Add("Abril");
                            if (Model.Mayo == 1) meses.Add("Mayo");
                            if (Model.Junio == 1) meses.Add("Junio");
                            if (Model.Julio == 1) meses.Add("Julio");
                            if (Model.Agosto == 1) meses.Add("Agosto");
                            if (Model.Septiembre == 1) meses.Add("Septiembre");
                            if (Model.Octubre == 1) meses.Add("Octubre");
                            if (Model.Noviembre == 1) meses.Add("Noviembre");
                            if (Model.Diciembre == 1) meses.Add("Diciembre");
                        }
                        @string.Join(", ", meses)
                    </td>
                </tr>
                <tr>
                    <td>Estado</td>
                    <td>
                        @switch (Model.StatusId)
                        {
                            case 1:
                                <span class="text-danger">Rechazado</span>
                                break;
                            case 2:
                                <span class="text-warning">Pendiente</span>
                                break;
                            case 3:
                                <span class="text-success">Aprobado</span>
                                break;
                        }
                    </td>
                </tr>
                <tr>
                    <td>Fecha</td>
                    <td>@Model.Fecha.ToShortDateString()</td>
                </tr>
                @if (Model.MotivoRechazo != null)
                {
                    <tr>
                        <td>Motivo de Rechazo</td>
                        <td>@Model.MotivoRechazo</td>
                    </tr>
                }
            }
            else if (Model is Proyecto)
            {
                <tr>
                    <td>Valor Estimado</td>
                    <td>@Model.ValorEstimado</td>
                </tr>
				<tr>
                    <td>Descripción</td>
                    <td>@Model.Descripcion</td>
                </tr>
                <tr>
                    <td>Viabilidad Comercial</td>
                    <td>@Model.ViabilidadComercial</td>
                </tr>
                <tr>
                    <td>Viabilidad Técnica</td>
                    <td>@Model.ViabilidadTecnica</td>
                </tr>
                <tr>
                    <td>Viabilidad Legal</td>
                    <td>@Model.ViabilidadLegal</td>
                </tr>
                <tr>
                    <td>Viabilidad de Gestión</td>
                    <td>@Model.ViabilidadGestion</td>
                </tr>
                <tr>
                    <td>Viabilidad de Impacto Ambiental</td>
                    <td>@Model.ViabilidadImpactoAmbiental</td>
                </tr>
                <tr>
                    <td>Viabilidad Financiera</td>
                    <td>@Model.ViabilidadFinanciera</td>
                </tr>
                <tr>
                    <td>Estado</td>
                    <td>
                        @switch (Model.StatusId)
                        {
                            case 1:
                                <span class="text-danger">Rechazado</span>
                                break;
                            case 2:
                                <span class="text-warning">Pendiente</span>
                                break;
                            case 3:
                                <span class="text-success">Aprobado</span>
                                break;
                        }
                    </td>
                </tr>
                <tr>
                    <td>Fecha</td>
                    <td>@Model.Fecha.ToShortDateString()</td>
                </tr>
                @if (Model.MotivoRechazo != null)
                {
                    <tr>
                        <td>Motivo de Rechazo</td>
                        <td>@Model.MotivoRechazo</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
<div>
    <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
</div>
